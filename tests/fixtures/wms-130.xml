<?xml version="1.0" encoding="UTF-8"?>
<WMS_Capabilities version="1.3.0" xmlns="http://www.opengis.net/wms"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.opengis.net/wms http://schemas.opengis.net/wms/1.3.0/capabilities_1_3_0.xsd">
<Service>
  <Name>WMS</Name>
  <Title>Test WMS 1.3.0 Service</Title>
  <Abstract>A minimal WMS 1.3.0 service for testing MapMLify</Abstract>
</Service>
<Capability>
  <Request>
    <GetCapabilities>
      <Format>text/xml</Format>
      <DCPType><HTTP><Get><OnlineResource xlink:href="https://test.example.com/wms?"/></Get></HTTP></DCPType>
    </GetCapabilities>
    <GetMap>
      <Format>image/png</Format>
      <Format>image/jpeg</Format>
      <DCPType><HTTP><Get><OnlineResource xlink:href="https://test.example.com/wms?"/></Get></HTTP></DCPType>
    </GetMap>
    <GetFeatureInfo>
      <Format>text/html</Format>
      <Format>application/json</Format>
      <DCPType><HTTP><Get><OnlineResource xlink:href="https://test.example.com/wms?"/></Get></HTTP></DCPType>
    </GetFeatureInfo>
  </Request>
  <Layer queryable="1">
    <Title>Test WMS Service</Title>
    <CRS>EPSG:4326</CRS>
    <CRS>EPSG:3857</CRS>
    <CRS>EPSG:3978</CRS>
    <EX_GeographicBoundingBox>
      <westBoundLongitude>-180</westBoundLongitude>
      <eastBoundLongitude>180</eastBoundLongitude>
      <southBoundLatitude>-90</southBoundLatitude>
      <northBoundLatitude>90</northBoundLatitude>
    </EX_GeographicBoundingBox>
    <BoundingBox CRS="EPSG:4326" minx="-90" miny="-180" maxx="90" maxy="180"/>
    <Attribution>
      <Title>Test Attribution</Title>
      <OnlineResource xlink:href="https://test.example.com/license"/>
    </Attribution>
    <Layer queryable="1" opaque="0">
      <Name>temperature</Name>
      <Title>Temperature Layer</Title>
      <Abstract>A queryable layer with styles and a time dimension</Abstract>
      <EX_GeographicBoundingBox>
        <westBoundLongitude>-141</westBoundLongitude>
        <eastBoundLongitude>-52</eastBoundLongitude>
        <southBoundLatitude>42</southBoundLatitude>
        <northBoundLatitude>84</northBoundLatitude>
      </EX_GeographicBoundingBox>
      <BoundingBox CRS="EPSG:3857" minx="-15696201" miny="5160979" maxx="-5788989" maxy="18764657"/>
      <Dimension name="time" units="ISO8601" default="2026-01-15T12:00:00Z">2026-01-15T00:00:00Z,2026-01-15T06:00:00Z,2026-01-15T12:00:00Z</Dimension>
      <MetadataURL type="TC211">
        <Format>text/xml</Format>
        <OnlineResource xlink:type="simple" xlink:href="https://test.example.com/metadata/temperature"/>
      </MetadataURL>
      <Style>
        <Name>default</Name>
        <Title>Default Style</Title>
        <LegendURL width="150" height="50">
          <Format>image/png</Format>
          <OnlineResource xlink:type="simple" xlink:href="https://test.example.com/legend/temperature/default"/>
        </LegendURL>
      </Style>
      <Style>
        <Name>contour</Name>
        <Title>Contour Style</Title>
        <LegendURL width="150" height="50">
          <Format>image/png</Format>
          <OnlineResource xlink:type="simple" xlink:href="https://test.example.com/legend/temperature/contour"/>
        </LegendURL>
      </Style>
    </Layer>
    <Layer queryable="0" opaque="0">
      <Name>boundaries</Name>
      <Title>Administrative Boundaries</Title>
      <Abstract>A non-queryable layer without dimensions</Abstract>
      <EX_GeographicBoundingBox>
        <westBoundLongitude>-141</westBoundLongitude>
        <eastBoundLongitude>-52</eastBoundLongitude>
        <southBoundLatitude>42</southBoundLatitude>
        <northBoundLatitude>84</northBoundLatitude>
      </EX_GeographicBoundingBox>
      <Style>
        <Name>default</Name>
        <Title>Default</Title>
      </Style>
    </Layer>
  </Layer>
</Capability>
</WMS_Capabilities>
